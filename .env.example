# ============================================================================
# Bunker OS v3 — ortam değişkenleri (yalnızca ADLAR; gerçek değer ASLA commit edilmez)
# ============================================================================

# --- Veritabanı ---
DATABASE_URL=postgres://bunker_user:CHANGE_ME@localhost:5432/bunker

# --- LLM (TEK sağlayıcı: Anthropic) ---
ANTHROPIC_API_KEY=
# Model kimlikleri (opsiyonel override; varsayılanlar lib/llm/models.ts içinde)
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6

# --- Dashboard auth (MVP: tek paylaşılan parola + imzalı cookie) ---
AUTH_SECRET=CHANGE_ME_long_random_string
AUTH_PASSWORD=CHANGE_ME

# --- Gmail (Hermes outreach) — OAuth2 refresh token akışı ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=hermes@example.com

# --- Entegrasyonlar ---
HUBSPOT_ACCESS_TOKEN=
SERPAPI_KEY=
INSTANTLY_API_KEY=
SLACK_BOT_TOKEN=
SLACK_WEBHOOK_URL=
CALCOM_API_KEY=

# --- Worker ---
# Worker cron'larını kapatmak için (CI/local): WORKER_ENABLED=false
WORKER_ENABLED=true

# --- Tenant ---
# Varsayılan tek-tenant slug (multi-tenant'a kadar)
DEFAULT_TENANT_SLUG=kiwi
