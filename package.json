{
  "name": "crew-os",
  "version": "0.1.0",
  "private": true,
  "description": "Crew OS — agentic satış/ops işletim sistemi (dashboard + ajan worker). Twenty CRM + Hermes + Frida. KiwiAI Lab.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "worker": "node --env-file-if-exists=.env --import tsx src/worker/index.ts",
    "worker:dev": "node --env-file-if-exists=.env --import tsx --watch src/worker/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env --import tsx src/db/migrate.ts",
    "db:seed": "node --env-file-if-exists=.env --import tsx scripts/seed.ts",
    "db:seed:kb": "node --env-file-if-exists=.env --import tsx scripts/seed-kb.ts",
    "hermes:dryrun": "node --env-file-if-exists=.env --import tsx scripts/hermes-dryrun.ts",
    "crew:dryrun": "node --env-file-if-exists=.env --import tsx scripts/crew-dryrun.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "drizzle-orm": "^0.38.3",
    "googleapis": "^144.0.0",
    "next": "^15.1.4",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
